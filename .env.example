# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.

# Hugging Face token for authenticated model downloads (required for gated models like Llama).
# Create a token at: https://huggingface.co/settings/tokens
export HUGGING_FACE_TOKEN=hf_your_token_here

# Kubernetes namespace (default: vllm)
# export NAMESPACE=vllm

# Path to kubeconfig (default: ~/.kube/config_k3s)
# export KUBECONFIG=~/.kube/config_k3s

# External domain used for all Ingress hostnames and CLI tools.
# Used by: make deploy-*, make models, make test, make toggle-model
# Example: k3s.example.com
export EXTERN_DOMAIN=<your-domain>

# Master key for the LiteLLM proxy (required for make deploy-litellm).
# Used as the API key for all requests to the LiteLLM endpoint.
export LITELLM_MASTER_KEY=sk-your-secret-key
